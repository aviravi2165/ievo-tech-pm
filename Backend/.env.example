# Copy this to .env and fill in your values

PORT=3001

# MS SQL Server
DB_SERVER=localhost
DB_DATABASE=IevoERP
DB_USER=sa
DB_PASSWORD=your_password_here
DB_PORT=1433
DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true

# JWT — must match the secret used by your ERP auth service
JWT_SECRET=replace_with_a_long_random_secret

# CORS — frontend origin
CORS_ORIGIN=http://localhost:5173

# File uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=25
FILE_STORAGE=postgres

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# Nodemailer (optional — offline email digest)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=I.EVO ERP <noreply@ievo.in>
