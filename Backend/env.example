# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001

# ── Database (MSSQL) ──────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=1433
DB_DATABASE=ievo-tech-pm
DB_USER=sa
DB_PASSWORD=YourStrong@Passw0rd

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_something_long_and_random
JWT_EXPIRES_IN=8h

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ── File uploads ──────────────────────────────────────────────────────────────
FILE_STORAGE_ROOT=/Users/jatin/Documents/DOC_UPLOADS
MAX_FILE_SIZE_MB=100

# ── Email (Nodemailer) ────────────────────────────────────────────────────────
# Used to send welcome emails to newly registered users.
#
# Gmail example:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=youraddress@gmail.com
#   SMTP_PASS=your_app_specific_password   ← generate at myaccount.google.com/apppasswords
#
# Office 365 / Outlook example:
#   SMTP_HOST=smtp.office365.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=youraddress@yourdomain.com
#   SMTP_PASS=your_password
#
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=I.EVO ERP <noreply@ievo.in>

# URL shown in the welcome email's "Open I.EVO ERP" button
APP_URL=http://localhost:5173
