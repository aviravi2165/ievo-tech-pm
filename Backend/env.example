PORT=3001

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432 {DEFAULT PORT}
DB_DATABASE= {DB NAME}
DB_USER=postgres
DB_PASSWORD={PASSWORD}

# JWT
JWT_SECRET={RANDOM 32 bit key}
JWT_EXPIRES_IN=8h

# CORS
CORS_ORIGIN=http://localhost:5173

# File uploads
FILE_STORAGE_PROVIDER=disk
FILE_STORAGE_ROOT=./storage
MAX_FILE_SIZE_MB=100
FILE_STORAGE=postgres

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=500
RATE_LIMIT_READ_MAX=1000
RATE_LIMIT_WRITE_MAX=300

# Nodemailer (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=I.EVO ERP <noreply@ievo.in>PORT=3001

